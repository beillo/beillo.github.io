---
import Base from "../layouts/Base.astro";
---

<Base title="About">
  <h1>About</h1>

  <div class="intro" style="margin-top: 1.5rem;">
    <p>
      I'm Lucas Beillo, an environmental engineer and data analyst based in A Coruña, Galicia.
      Originally from Brazil, I studied Cartographic Engineering before switching to
      Environmental Engineering at UNESP, where my thesis focused on urban heat islands
      and vegetation cover using satellite imagery and GIS.
    </p>
    <p>
      My work sits at the boundary between environmental science and data engineering —
      I care about building systems that extract meaning from spatial and environmental data.
    </p>
    <p>
      Currently pursuing a Master's in Computer Engineering (UNED) and building
      <a href="/projects/recolle">Recolle</a>, a civic-tech project for urban environmental reporting.
    </p>
  </div>

  <div class="section">
    <h2>Experience</h2>
    <div class="card-list">
      <div class="card" style="display: block; cursor: default;">
        <div style="display: flex; justify-content: space-between; gap: 1rem;">
          <span class="card-title">Ethercity</span>
          <span class="card-meta">2021–2024</span>
        </div>
        <div class="card-desc">Data analyst — anti-fraud, web data extraction, dashboards</div>
        <div class="card-tags" style="margin-top: 0.5rem;">
          <span class="tag">Python</span><span class="tag">MySQL</span><span class="tag">MongoDB</span><span class="tag">Looker Studio</span>
        </div>
      </div>
      <div class="card" style="display: block; cursor: default;">
        <div style="display: flex; justify-content: space-between; gap: 1rem;">
          <span class="card-title">Geopixel / Aerocarta</span>
          <span class="card-meta">2019–2021</span>
        </div>
        <div class="card-desc">Geospatial analyst — cadastral mapping, spatial analysis</div>
        <div class="card-tags" style="margin-top: 0.5rem;">
          <span class="tag">QGIS</span><span class="tag">GIS</span><span class="tag">cartography</span>
        </div>
      </div>
    </div>
  </div>

  <div class="section">
    <h2>Education</h2>
    <div class="card-list">
      <div class="card" style="display: block; cursor: default;">
        <div style="display: flex; justify-content: space-between; gap: 1rem;">
          <span class="card-title">Máster en Ingeniería Informática</span>
          <span class="card-meta">2024–</span>
        </div>
        <div class="card-desc">UNED, Spain · In progress</div>
      </div>
      <div class="card" style="display: block; cursor: default;">
        <div style="display: flex; justify-content: space-between; gap: 1rem;">
          <span class="card-title">Environmental Engineering</span>
          <span class="card-meta">2015–2023</span>
        </div>
        <div class="card-desc">UNESP, Brazil · Thesis: Urban heat island analysis using GEE & QGIS</div>
      </div>
    </div>
  </div>

  <div class="section">
    <h2>Languages</h2>
    <p class="mono muted">Portuguese (native) · Spanish · English</p>
  </div>

  <div class="section">
    <h2>Contact</h2>
    <p>
      <a href="mailto:lucas@beillo.dev">lucas@beillo.dev</a> ·
      <a href="https://linkedin.com/in/lucasbeillo" target="_blank" rel="noopener">LinkedIn</a> ·
      <a href="https://github.com/lucasbeillo" target="_blank" rel="noopener">GitHub</a>
    </p>
  </div>
</Base>
