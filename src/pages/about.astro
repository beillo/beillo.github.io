---
import Base from "../layouts/Base.astro";
---

<Base title="About">
  <h1>About</h1>

  <div class="intro" style="margin-top: 1.5rem;">
    <p>
      I'm Lucas Beillo, a data analyst and data engineer based in A Coruña, Galicia. I work across
      business intelligence, analytics engineering, and the pipelines that feed them. Originally from
      Brazil, I came into data through engineering — first cartographic, then environmental at UNESP —
      which is where I learned to work with messy, spatial, real-world data.
    </p>
    <p>
      Today my work is squarely in the data stack: SQL and Python for modelling and analysis, dbt for
      transformations, and Power BI / Looker Studio for the dashboards stakeholders live in. The GIS and
      environmental background is a differentiator, not the headline — it just means geospatial and sensor
      data don't scare me.
    </p>
    <p>
      Currently pursuing a Master's in Computer Engineering (UNED) and building
      Recolle, a civic-tech project that turns urban environmental
      reports into structured, analysable data.
    </p>
  </div>

  <div class="section">
    <h2>Experience</h2>
    <div class="card-list">
      <div class="card" style="display: block; cursor: default;">
        <div style="display: flex; justify-content: space-between; gap: 1rem;">
          <span class="card-title">Geopixel</span>
          <span class="card-meta">2024–2026</span>
        </div>
        <div class="card-desc">Geospatial data analyst — spatial analysis and cartographic production</div>
        <div class="card-tags" style="margin-top: 0.5rem;">
          <span class="tag">QGIS</span><span class="tag">Python</span><span class="tag">GIS</span>
        </div>
      </div>
      <div class="card" style="display: block; cursor: default;">
        <div style="display: flex; justify-content: space-between; gap: 1rem;">
          <span class="card-title">Ethercity</span>
          <span class="card-meta">2021–2024</span>
        </div>
        <div class="card-desc">Data analyst — anti-fraud, web data extraction, dashboards</div>
        <div class="card-tags" style="margin-top: 0.5rem;">
          <span class="tag">Python</span><span class="tag">MySQL</span><span class="tag">MongoDB</span><span class="tag">Looker Studio</span>
        </div>
      </div>
      <div class="card" style="display: block; cursor: default;">
        <div style="display: flex; justify-content: space-between; gap: 1rem;">
          <span class="card-title">Geobase</span>
          <span class="card-meta">2021</span>
        </div>
        <div class="card-desc">Geospatial analyst — cadastral mapping and spatial data</div>
        <div class="card-tags" style="margin-top: 0.5rem;">
          <span class="tag">QGIS</span><span class="tag">GIS</span><span class="tag">cartography</span>
        </div>
      </div>
      <div class="card" style="display: block; cursor: default;">
        <div style="display: flex; justify-content: space-between; gap: 1rem;">
          <span class="card-title">Aerocarta</span>
          <span class="card-meta">2013</span>
        </div>
        <div class="card-desc">Cartography and photogrammetry — mapping production</div>
        <div class="card-tags" style="margin-top: 0.5rem;">
          <span class="tag">cartography</span><span class="tag">photogrammetry</span>
        </div>
      </div>
    </div>
  </div>

  <div class="section">
    <h2>Education</h2>
    <div class="card-list">
      <div class="card" style="display: block; cursor: default;">
        <div style="display: flex; justify-content: space-between; gap: 1rem;">
          <span class="card-title">Máster en Ingeniería Informática</span>
          <span class="card-meta">2024–</span>
        </div>
        <div class="card-desc">UNED, Spain · In progress</div>
      </div>
      <div class="card" style="display: block; cursor: default;">
        <div style="display: flex; justify-content: space-between; gap: 1rem;">
          <span class="card-title">Environmental Engineering</span>
          <span class="card-meta">2015–2023</span>
        </div>
        <div class="card-desc">UNESP, Brazil · Thesis: Urban heat island analysis using GEE & QGIS</div>
      </div>
    </div>
  </div>

  <div class="section">
    <h2>Languages</h2>
    <p class="mono muted">Portuguese (native) · Spanish · English</p>
  </div>

  <div class="section">
    <h2>Contact</h2>
    <p>
      <a href="mailto:lucas.beillo@live.com">lucas.beillo@live.com</a> ·
      <a href="https://www.linkedin.com/in/lucasbeillo/" target="_blank" rel="noopener">LinkedIn</a> ·
      <a href="https://github.com/beillo" target="_blank" rel="noopener">GitHub</a>
    </p>
  </div>
</Base>
