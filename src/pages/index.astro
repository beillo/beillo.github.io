---
import Base from "../layouts/Base.astro";
---

<Base>
  <div class="intro">
    <h1>Lucas Beillo</h1>
    <p class="muted mono" style="margin-bottom: 2rem;">Environmental engineer & data analyst · A Coruña, Spain</p>

    <p>
      I work at the intersection of geospatial data, environmental analysis, and software — building tools that
      make complex spatial information useful and legible.
    </p>
    <p>
      Background in GIS, remote sensing, and data engineering. Currently building
      <a href="https://recolle.app" target="_blank" rel="noopener">Recolle</a>,
      a civic-tech platform for urban waste reporting in Galicia.
    </p>
    <p>
      When not at the computer, I'm usually running.
      Completed the <a href="/running">Madrid Marathon</a> in April 2026.
    </p>
  </div>

  <div class="section">
    <h2>Recent projects</h2>
    <div class="card-list">
      <a class="card" href="/projects/recolle">
        <span class="card-title">Recolle</span>
        <span class="card-meta">2025–</span>
        <span class="card-desc">Civic-tech platform for urban waste reporting and environmental monitoring in A Coruña.</span>
        <div class="card-tags">
          <span class="tag">Python</span>
          <span class="tag">GIS</span>
          <span class="tag">civic-tech</span>
        </div>
      </a>
      <a class="card" href="/projects/urban-heat">
        <span class="card-title">Urban Heat Island Analysis</span>
        <span class="card-meta">2023</span>
        <span class="card-desc">Thesis work analyzing vegetation cover and heat distribution in Bauru using GEE and QGIS.</span>
        <div class="card-tags">
          <span class="tag">Google Earth Engine</span>
          <span class="tag">QGIS</span>
          <span class="tag">Python</span>
        </div>
      </a>
    </div>
  </div>

  <div class="section">
    <h2>Stack</h2>
    <p class="mono muted">Python · SQL · Power BI · QGIS · GEE · dbt · Git</p>
  </div>
</Base>
