---
import Base from "../layouts/Base.astro";
---

<Base title="Projects">
  <h1>Projects</h1>
  <p class="muted" style="margin-top: 0.5rem; margin-bottom: 0;">Selected work in data analytics, BI, pipelines — and the occasional map.</p>

  <div class="section">
    <div class="card-list">
      <a class="card" href="/projects/recolle">
        <span class="card-title">Recolle</span>
        <span class="card-meta">2025–present</span>
        <span class="card-desc">
          Civic-tech platform that ingests urban waste and environmental reports and turns them into
          structured, queryable data for Galician cities. Python data pipeline, spatial layer, open data.
        </span>
        <div class="card-tags">
          <span class="tag">Python</span>
          <span class="tag">SQL</span>
          <span class="tag">data pipeline</span>
          <span class="tag">open data</span>
        </div>
      </a>

      <a class="card" href="/projects/anti-fraud-pipeline">
        <span class="card-title">Anti-fraud Data Pipeline</span>
        <span class="card-meta">2021–2024</span>
        <span class="card-desc">
          Built and maintained data extraction and monitoring pipelines at Ethercity, combining
          web data collection, SQL modelling, and Looker Studio dashboards for fraud detection and reporting.
        </span>
        <div class="card-tags">
          <span class="tag">Python</span>
          <span class="tag">SQL</span>
          <span class="tag">MySQL</span>
          <span class="tag">Looker Studio</span>
        </div>
      </a>

      <a class="card" href="/projects/urban-heat">
        <span class="card-title">Urban Heat Island Analysis — Bauru</span>
        <span class="card-meta">2023</span>
        <span class="card-desc">
          Thesis research analyzing the relationship between urban vegetation cover and surface temperature
          in Bauru, Brazil, using Google Earth Engine and QGIS — a deep dive in geospatial data analysis.
        </span>
        <div class="card-tags">
          <span class="tag">Google Earth Engine</span>
          <span class="tag">QGIS</span>
          <span class="tag">Python</span>
          <span class="tag">remote sensing</span>
        </div>
      </a>

      <a class="card" href="/projects/cadastral-gis">
        <span class="card-title">Cadastral & Geospatial Analysis</span>
        <span class="card-meta">2019–2021</span>
        <span class="card-desc">
          Geospatial and cadastral mapping work at Geopixel and Aerocarta,
          producing spatial analysis and cartographic deliverables for public sector clients.
        </span>
        <div class="card-tags">
          <span class="tag">QGIS</span>
          <span class="tag">cartography</span>
          <span class="tag">GIS</span>
        </div>
      </a>
    </div>
  </div>
</Base>
