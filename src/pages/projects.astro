---
import Base from "../layouts/Base.astro";
---

<Base title="Projects">
  <h1>Projects</h1>
  <p class="muted" style="margin-top: 0.5rem; margin-bottom: 0;">Selected work in data analytics, BI, pipelines — and the occasional map.</p>

  <div class="section">
    <div class="card-list">
      <a class="card" href="https://recolle-v02.vercel.app" target="_blank" rel="noopener">
        <span class="card-title">Recolle</span>
        <span class="card-meta">live</span>
        <span class="card-desc">
          Civic-tech app for geolocated incident reporting, built to verify the quality of municipal
          cleaning services. Lets people log observations with photo, category, and GPS location,
          stored in real time. Mobile-first, in production.
        </span>
        <div class="card-tags">
          <span class="tag">React 18</span>
          <span class="tag">Leaflet</span>
          <span class="tag">Firebase Firestore</span>
          <span class="tag">Python</span>
          <span class="tag">SQL</span>
        </div>
      </a>

      <div class="card">
        <span class="card-title">Urban Heat &amp; Vegetation Viewer</span>
        <span class="card-desc">
          Interactive geospatial viewer derived from my undergrad thesis: explore the spatio-temporal
          relationship between vegetation cover and surface temperature in Bauru, Brazil, built on
          Google Earth Engine data and rendered as a web map with time-series charts.
        </span>
        <div class="card-tags">
          <span class="tag">React</span>
          <span class="tag">MapLibre GL JS</span>
          <span class="tag">Recharts</span>
          <span class="tag">Tailwind</span>
          <span class="tag">Cloud Optimized GeoTIFF</span>
          <span class="tag">Google Earth Engine</span>
        </div>
      </div>

      <div class="card" style="display: block;">
        <div style="display: flex; justify-content: space-between; gap: 1rem; align-items: baseline;">
          <span class="card-title">Life Tracker <span class="mono muted">(healthkit)</span></span>
          <span class="card-meta">in development</span>
        </div>
        <div class="card-desc">
          Personal data warehouse aggregating 5 sources (Garmin, Notion, Streaks, Google Sheets, Instagram)
          into a single analytical model. Full pipeline: Python → DuckDB → dbt → Flask API → React dashboard.
        </div>
        <div class="card-tags">
          <span class="tag">Python 3.12</span>
          <span class="tag">DuckDB</span>
          <span class="tag">dbt</span>
          <span class="tag">Flask</span>
          <span class="tag">React</span>
          <span class="tag">Recharts</span>
          <span class="tag">pandas</span>
          <span class="tag">scikit-learn</span>
        </div>
        <div class="card-meta" style="margin-top: 0.6rem;">Private repo</div>
      </div>
    </div>
  </div>
</Base>
